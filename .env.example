# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Add to .env.local for local development. Omit or leave empty to disable analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# OGD Files API URL
NEXT_PUBLIC_OGD_FILES_API_URL=

# Master switch for in-app assistant (UI + /api/chat). Opt-in: must be true to enable.
AI_ASSISTANT_ENABLED=false

# Chat AI provider: ollama (default) | openai
AI_PROVIDER=

# Ollama (local inference) — required when AI_PROVIDER=ollama
OLLAMA_MODEL=
OLLAMA_BASE_URL=

# OpenAI — required when AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
